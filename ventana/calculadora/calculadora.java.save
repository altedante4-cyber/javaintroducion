import javax.swing.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
public class calculadora  extends JFrame implements ActionListener {
    
    private JFrame ventana;
    private JPanel panel ;
    private JTextField pantalla ;
    private JTextField resultado ;
    private JButton boton [];
    private JButton boton_especial [];
    private int numero ;
    private String texto="" ;
    public calculadora(){

        panel = new JPanel();
        pantalla = new JTextField(12);
        resultado = new JTextField(12);
        panel.add(pantalla);
        panel.add(resultado);
        numero =  0 ;
	boton = new JButton[10];
	boton_especial = new JButton[5];
	for (int i = 0 ; i < boton.length; i++){
		boton[i]= new JButton(String.valueOf(i));
	}

	String valores [] = {"+","-","*","/","="};

	for(int i = 0 ; i < boton_especial.length ; i++){
		boton_especial[i] = new JButton(valores[i]);
	}
	for(JButton btn : boton_especial){
		btn.addActionListener(this);
	}

	for (JButton btn : boton) {
	    btn.addActionListener(this);
}

	for(JButton j : boton){
		panel.add(j);
	}
	for(JButton p : boton_especial){
		panel.add(p);
	}

        this.setSize(200,200);
        this.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);          
        this.add(panel);
        this.setVisible(true);
        }


    public void actionPerformed(ActionEvent e ){
    	JButton escuchar = (JButton) e.getSource() ;
	if(!escuchar.getText().equals("=")){
	  	texto += escuchar.getText();
		pantalla.setText(texto);
	}

	if(escuchar.getText().equals("=")){

		String separar [] = texto.split("[+\\-*/]");
		String valora = separar[0];
		String valorb= separar[1];
		int a = Integer.parseInt(valora);
		int b = Integer.parseInt(valorb);
		char tipo_operacion ;
		for(int i = 0 ; i < texto.length();i++){
			char c = texto.charAt(i);
			
		}
		
		resultado.setText(String.valueOf(a + b));

}
	
	}
    
}
